# Ignore all runtime data (library.json, downloaded files, scans, temp, etc.)
data/

# If you want to keep the folder but not the files:
# !data/.gitkeep

# Ignore logs
*.log

# Ignore temporary build files
/dist
/build

# Ignore OS-specific junk
.DS_Store
Thumbs.db

# Ignore editor-specific files
.vscode/
.idea/

# Go build output
/bin/
*.exe
*.dll
*.so
*.dylib

# Node modules (frontend)
node_modules/

# Environment variables
.env
.env.*
